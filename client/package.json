    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^26.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^3.2.4"
  }
}
