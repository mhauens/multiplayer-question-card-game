{
  "name": "kampf-gegen-das-spiessertum",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "dev:server": "pnpm --filter server dev",
    "dev:client": "pnpm --filter client dev",
    "lint": "eslint client/src server/src server/test --ext .ts,.tsx",
    "lint:fix": "eslint client/src server/src server/test --ext .ts,.tsx --fix",
    "test": "pnpm --filter client test && pnpm --filter server test",
    "build": "pnpm --filter client build && pnpm --filter server build",
    "start": "pnpm --filter server start"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.38.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "typescript-eslint": "^8.46.1"
  }
}
